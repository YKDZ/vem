{
  "$schema": "./node_modules/turbo/schema.json",
  "boundaries": {
    "tags": {
      "app": {
        "dependencies": {
          "allow": ["library", "tooling"]
        }
      },
      "library": {
        "dependencies": {
          "allow": ["library"]
        }
      },
      "native": {
        "dependencies": {
          "allow": ["library", "native"]
        }
      },
      "tooling": {
        "dependencies": {
          "allow": ["library", "native", "tooling"]
        }
      }
    }
  },
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "fmt": {
      "outputs": []
    },
    "test": {
      "outputs": []
    },
    "test:e2e": {
      "outputs": []
    }
  }
}
