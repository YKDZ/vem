{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vem.example.invalid/schemas/vision-release-trust-policy/v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "kind", "verifierDigest", "approvedIdentities"],
  "properties": {
    "schemaVersion": { "const": "vem-vision-release-trust-policy/v1" },
    "kind": { "const": "vision-release-trust-policy" },
    "verifierDigest": { "$ref": "#/$defs/digest" },
    "approvedIdentities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "descriptor",
        "attestation",
        "sbom",
        "provenance",
        "conformance",
        "approval"
      ],
      "properties": {
        "descriptor": { "$ref": "#/$defs/identities" },
        "attestation": { "$ref": "#/$defs/identities" },
        "sbom": { "$ref": "#/$defs/identities" },
        "provenance": { "$ref": "#/$defs/identities" },
        "conformance": { "$ref": "#/$defs/identities" },
        "approval": { "$ref": "#/$defs/identities" }
      }
    }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "identities": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^spki-sha256:[a-f0-9]{64}$" }
    }
  }
}
