{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vem.example.invalid/schemas/vision-release-approval/v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "identity",
    "releaseVersion",
    "bundleDigest",
    "descriptorDigest",
    "attestationDigest",
    "conformanceEvidenceDigest",
    "approverIdentity"
  ],
  "properties": {
    "schemaVersion": { "const": "vem-vision-release-approval/v1" },
    "kind": { "const": "vision-release-approval" },
    "identity": { "$ref": "#/$defs/digest" },
    "releaseVersion": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "bundleDigest": { "$ref": "#/$defs/digest" },
    "descriptorDigest": { "$ref": "#/$defs/digest" },
    "attestationDigest": { "$ref": "#/$defs/digest" },
    "conformanceEvidenceDigest": { "$ref": "#/$defs/digest" },
    "approverIdentity": {
      "type": "string",
      "pattern": "^vem-release-approval:[a-z0-9-]+$"
    }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
  }
}
