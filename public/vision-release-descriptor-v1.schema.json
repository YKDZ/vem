{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vem.example.invalid/schemas/vision-release-descriptor/v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "identity",
    "releaseVersion",
    "bundle",
    "entrypoint",
    "lifecycle",
    "configuration",
    "health",
    "protocol",
    "sbom",
    "provenance"
  ],
  "properties": {
    "schemaVersion": { "const": "vem-vision-release-descriptor/v1" },
    "kind": { "const": "vision-release-descriptor" },
    "identity": { "$ref": "#/$defs/digest" },
    "releaseVersion": { "$ref": "#/$defs/semver" },
    "bundle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["digest", "bytes", "platform", "format", "extractor"],
      "properties": {
        "digest": { "$ref": "#/$defs/digest" },
        "bytes": { "type": "integer", "minimum": 1 },
        "platform": {
          "type": "object",
          "additionalProperties": false,
          "required": ["os", "architecture"],
          "properties": {
            "os": { "const": "windows" },
            "architecture": { "enum": ["x86_64", "arm64"] }
          }
        },
        "format": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._+-]{0,63}$"
        },
        "extractor": {
          "type": "object",
          "additionalProperties": false,
          "required": ["contractVersion", "handler"],
          "properties": {
            "contractVersion": { "const": "vem-vision-extractor/v1" },
            "handler": { "enum": ["zip-safe-v1", "vendor-installer-v1"] }
          }
        }
      }
    },
    "entrypoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "arguments"],
      "properties": {
        "command": { "$ref": "#/$defs/relativePath" },
        "arguments": {
          "type": "array",
          "items": { "type": "string", "maxLength": 1024 }
        }
      }
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requiresInteractiveSession", "shutdownTimeoutMs"],
      "properties": {
        "requiresInteractiveSession": { "const": true },
        "shutdownTimeoutMs": {
          "type": "integer",
          "minimum": 100,
          "maximum": 120000
        }
      }
    },
    "configuration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format", "schemaVersion", "argument"],
      "properties": {
        "format": { "enum": ["json", "yaml", "toml"] },
        "schemaVersion": { "type": "string", "minLength": 1 },
        "argument": {
          "type": "string",
          "pattern": "^--[A-Za-z0-9][A-Za-z0-9-]*$"
        }
      }
    },
    "health": {
      "type": "object",
      "additionalProperties": false,
      "required": ["port", "path", "expectedStatus", "timeoutMs"],
      "properties": {
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "path": { "$ref": "#/$defs/loopbackPath" },
        "expectedStatus": { "type": "integer", "minimum": 200, "maximum": 299 },
        "timeoutMs": { "type": "integer", "minimum": 100, "maximum": 120000 }
      }
    },
    "protocol": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "webSocketPath"],
      "properties": {
        "version": { "const": "vem.vision.v1" },
        "webSocketPath": { "$ref": "#/$defs/loopbackPath" }
      }
    },
    "sbom": { "$ref": "#/$defs/evidence" },
    "provenance": { "$ref": "#/$defs/evidence" }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
    "semver": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "relativePath": {
      "type": "string",
      "pattern": "^(?![\\\\/])(?!.*(?:^|[\\\\/])\\.\\.(?:[\\\\/]|$))[A-Za-z0-9][A-Za-z0-9._-]*(?:[\\\\/][A-Za-z0-9][A-Za-z0-9._-]*)*$"
    },
    "loopbackPath": { "type": "string", "pattern": "^/[A-Za-z0-9._~\\-/]*$" },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identity", "digest"],
      "properties": {
        "identity": {
          "type": "string",
          "pattern": "^factory-evidence://sha256/[a-f0-9]{64}$"
        },
        "digest": { "$ref": "#/$defs/digest" },
        "format": { "enum": ["spdx-json", "cyclonedx-json"] },
        "predicateType": { "const": "https://slsa.dev/provenance/v1" }
      }
    }
  }
}
