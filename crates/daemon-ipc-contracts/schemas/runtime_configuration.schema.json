{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "number",
      "const": 1
    },
    "generation": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "bootstrap": {
      "type": "object",
      "properties": {
        "schemaVersion": {
          "type": "number",
          "const": 1
        },
        "provisioningApiBaseUrl": {
          "type": "string",
          "format": "uri"
        },
        "hardwareModel": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "topology": {
          "type": "object",
          "properties": {
            "identity": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128
            },
            "version": {
              "type": "string",
              "minLength": 1,
              "maxLength": 128
            }
          },
          "required": ["identity", "version"],
          "additionalProperties": false
        }
      },
      "required": [
        "schemaVersion",
        "provisioningApiBaseUrl",
        "hardwareModel",
        "topology"
      ],
      "additionalProperties": false
    },
    "profileCache": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "schemaVersion": {
              "type": "number",
              "const": 1
            },
            "generation": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "acceptedAt": {
              "type": "string",
              "format": "date-time",
              "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
            },
            "profile": {
              "type": "object",
              "properties": {
                "machine": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "format": "uuid",
                      "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
                    },
                    "code": {
                      "type": "string",
                      "minLength": 1,
                      "maxLength": 64
                    },
                    "name": {
                      "type": "string",
                      "minLength": 1,
                      "maxLength": 128
                    },
                    "status": {
                      "type": "string",
                      "minLength": 1,
                      "maxLength": 64
                    },
                    "locationLabel": {
                      "anyOf": [
                        {
                          "type": "string",
                          "minLength": 1,
                          "maxLength": 256
                        },
                        {
                          "type": "null"
                        }
                      ]
                    }
                  },
                  "required": ["id", "code", "name", "status", "locationLabel"],
                  "additionalProperties": false
                },
                "apiBaseUrl": {
                  "type": "string",
                  "format": "uri"
                },
                "runtimeEndpoints": {
                  "type": "object",
                  "properties": {
                    "apiBasePath": {
                      "type": "string",
                      "const": "/api"
                    },
                    "machineAuthTokenPath": {
                      "type": "string",
                      "const": "/api/machine-auth/token"
                    },
                    "machineApiBasePath": {
                      "type": "string",
                      "pattern": "^\\/api\\/machines\\/[^/]+$"
                    },
                    "mqttTopicPrefix": {
                      "type": "string",
                      "pattern": "^vem\\/machines\\/[^/]+$"
                    }
                  },
                  "required": [
                    "apiBasePath",
                    "machineAuthTokenPath",
                    "machineApiBasePath",
                    "mqttTopicPrefix"
                  ],
                  "additionalProperties": false
                },
                "mqttConnection": {
                  "type": "object",
                  "properties": {
                    "url": {
                      "type": "string",
                      "format": "uri"
                    },
                    "clientId": {
                      "type": "string",
                      "minLength": 1,
                      "maxLength": 128
                    },
                    "username": {
                      "anyOf": [
                        {
                          "type": "string",
                          "minLength": 1,
                          "maxLength": 128
                        },
                        {
                          "type": "null"
                        }
                      ]
                    }
                  },
                  "required": ["url", "clientId", "username"],
                  "additionalProperties": false
                },
                "hardwareProfile": {
                  "type": "object",
                  "properties": {
                    "profile": {
                      "type": "string",
                      "const": "production"
                    },
                    "controller": {
                      "type": "object",
                      "properties": {
                        "required": {
                          "type": "boolean",
                          "const": true
                        },
                        "protocol": {
                          "type": "string",
                          "const": "vem-vending-controller"
                        }
                      },
                      "required": ["required", "protocol"],
                      "additionalProperties": false
                    },
                    "paymentScanner": {
                      "type": "object",
                      "properties": {
                        "required": {
                          "type": "boolean",
                          "const": true
                        },
                        "supportsPaymentCode": {
                          "type": "boolean"
                        }
                      },
                      "required": ["required", "supportsPaymentCode"],
                      "additionalProperties": false
                    },
                    "vision": {
                      "type": "object",
                      "properties": {
                        "required": {
                          "type": "boolean"
                        },
                        "supportsRecommendations": {
                          "type": "boolean"
                        }
                      },
                      "required": ["required", "supportsRecommendations"],
                      "additionalProperties": false
                    }
                  },
                  "required": [
                    "profile",
                    "controller",
                    "paymentScanner",
                    "vision"
                  ],
                  "additionalProperties": false
                },
                "hardwareModel": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 128
                },
                "hardwareSlotTopology": {
                  "type": "object",
                  "properties": {
                    "identity": {
                      "type": "string",
                      "minLength": 1,
                      "maxLength": 128
                    },
                    "version": {
                      "type": "string",
                      "minLength": 1,
                      "maxLength": 128
                    }
                  },
                  "required": ["identity", "version"],
                  "additionalProperties": false
                },
                "paymentCapability": {
                  "type": "object",
                  "properties": {
                    "profile": {
                      "type": "string",
                      "const": "production"
                    },
                    "qrCodeEnabled": {
                      "type": "boolean"
                    },
                    "paymentCodeEnabled": {
                      "type": "boolean"
                    },
                    "serverTime": {
                      "type": "string",
                      "format": "date-time",
                      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
                    }
                  },
                  "required": [
                    "profile",
                    "qrCodeEnabled",
                    "paymentCodeEnabled",
                    "serverTime"
                  ],
                  "additionalProperties": false
                },
                "metadata": {
                  "type": "object",
                  "properties": {
                    "profileVersion": {
                      "type": "number",
                      "const": 1
                    },
                    "profileRevision": {
                      "type": "integer",
                      "exclusiveMinimum": 0,
                      "maximum": 9007199254740991
                    },
                    "claimCodeId": {
                      "type": "string",
                      "format": "uuid",
                      "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
                    },
                    "claimedAt": {
                      "type": "string",
                      "format": "date-time",
                      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
                    },
                    "serverTime": {
                      "type": "string",
                      "format": "date-time",
                      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
                    }
                  },
                  "required": [
                    "profileVersion",
                    "profileRevision",
                    "claimCodeId",
                    "claimedAt",
                    "serverTime"
                  ],
                  "additionalProperties": false
                }
              },
              "required": [
                "machine",
                "apiBaseUrl",
                "runtimeEndpoints",
                "mqttConnection",
                "hardwareProfile",
                "hardwareModel",
                "hardwareSlotTopology",
                "paymentCapability",
                "metadata"
              ],
              "additionalProperties": false
            }
          },
          "required": ["schemaVersion", "generation", "acceptedAt", "profile"],
          "additionalProperties": false
        },
        {
          "type": "null"
        }
      ]
    },
    "profileRefresh": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["unclaimed", "accepted", "degraded"]
        },
        "lastError": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": ["status", "lastError"],
      "additionalProperties": false
    },
    "configuredSecrets": {
      "type": "object",
      "properties": {
        "machineSecretConfigured": {
          "type": "boolean"
        },
        "mqttSigningSecretConfigured": {
          "type": "boolean"
        },
        "mqttPasswordConfigured": {
          "type": "boolean"
        }
      },
      "required": [
        "machineSecretConfigured",
        "mqttSigningSecretConfigured",
        "mqttPasswordConfigured"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "schemaVersion",
    "generation",
    "bootstrap",
    "profileCache",
    "profileRefresh",
    "configuredSecrets"
  ],
  "additionalProperties": false,
  "title": "EffectiveMachineRuntimeConfiguration"
}
