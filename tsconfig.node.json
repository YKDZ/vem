{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": [
    "vitest.config.ts",
    "oxlint.config.ts",
    "oxfmt.config.ts",
    "apps/*/oxlint.config.ts",
    "packages/*/oxlint.config.ts"
  ]
}
