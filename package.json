    "mermaid": "^11.15.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "oxlint-tsgolint": "^0.22.1",
    "playwright": "catalog:",
    "tsx": "catalog:",
    "turbo": "^2.9.8",
    "typescript": "catalog:",
    "unplugin-dts": "catalog:",
