{
  "private": true,
  "type": "module",
  "scripts": {
    "check": "pnpm check:script-inventory && pnpm check:admin-api-contracts && pnpm check:daemon-ipc-contracts && tsx node_modules/oxfmt/dist/cli.js . --check && cargo fmt --all -- --check && turbo typecheck lint test",
    "check:admin-api-contracts": "node --test scripts/check-admin-api-contracts.test.mjs scripts/check-admin-contract-e2e-ci.test.mjs && node scripts/check-admin-api-contracts.mjs && node scripts/check-admin-contract-e2e-ci.mjs",
    "check:daemon-ipc-contracts": "pnpm typecheck:scripts && pnpm test:daemon-ipc-contracts && pnpm generate:daemon-ipc-contracts -- --check && cargo test -p daemon-ipc-contracts && cargo test -p vending-core --test daemon_ipc_migration_guard && pnpm --filter machine test -- src/daemon/migration-guards.spec.ts",
    "check:factory-runtime-prep": "node scripts/check-factory-runtime-prep.mjs",
    "check:fix": "tsx node_modules/oxfmt/dist/cli.js . && cargo fmt --all && turbo lint -- --fix && turbo typecheck test",
    "check:machine-vision-deployment": "node scripts/check-machine-vision-deployment.mjs",
    "check:managed-update": "node scripts/check-managed-machine-update.mjs",
    "check:script-inventory": "node --test scripts/check-repository-script-inventory.test.mjs && node scripts/check-repository-script-inventory.mjs",
    "fmt": "tsx node_modules/oxfmt/dist/cli.js . && cargo fmt --all",
    "fmt:check": "tsx node_modules/oxfmt/dist/cli.js . --check && cargo fmt --all -- --check",
    "generate:daemon-ipc-contracts": "tsx scripts/daemon-ipc-contracts/generate-contracts.ts",
    "lint": "turbo lint",
    "lint:fix": "turbo lint -- --fix",
    "test": "node --test scripts/check-repository-script-inventory.test.mjs && turbo test",
    "test:daemon-ipc-contracts": "vitest run scripts/daemon-ipc-contracts/generate-contracts.spec.ts",
    "test:e2e": "turbo test:e2e",
    "typecheck": "turbo typecheck",
    "typecheck:scripts": "tsc -p tsconfig.scripts.json"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "catalog:",
    "jsdom": "^29.1.1",
    "marked": "^18.0.5",
    "mermaid": "^11.15.0",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "oxlint-tsgolint": "^0.23.0",
    "playwright": "catalog:",
    "tsx": "catalog:",
    "turbo": "^2.10.0",
    "typescript": "catalog:",
    "unplugin-dts": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
