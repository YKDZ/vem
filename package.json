{
  "private": true,
  "type": "module",
  "scripts": {
    "check": "node tools/check-ci.mjs",
    "check:admin-api-contracts": "node --test scripts/check-admin-api-contracts.test.mjs scripts/check-admin-contract-e2e-ci.test.mjs && node scripts/check-admin-api-contracts.mjs && node scripts/check-admin-contract-e2e-ci.mjs",
    "check:boundaries": "turbo boundaries --no-color",
    "check:daemon-ipc-contracts": "pnpm typecheck:scripts && pnpm test:daemon-ipc-contracts && pnpm generate:daemon-ipc-contracts -- --check && cargo test -p daemon-ipc-contracts && cargo test -p vending-core --test daemon_ipc_migration_guard && pnpm --filter machine test -- src/daemon/migration-guards.spec.ts",
    "check:fix": "tsx node_modules/oxfmt/dist/cli.js . && cargo fmt --all && turbo lint -- --fix && turbo typecheck test",
    "check:machine-customer-copy": "node --test scripts/check-machine-customer-payment-copy.test.mjs && pnpm --filter machine build && node scripts/check-machine-customer-payment-copy.mjs",
    "check:machine-e2e-ci": "node --test scripts/check-machine-e2e-ci.test.mjs",
    "check:machine-vision-deployment": "node scripts/check-machine-vision-deployment.mjs",
    "check:maintenance-relay-runbook": "node --test scripts/check-maintenance-relay-runbook.test.mjs",
    "check:maintenance-ssh-ca-secrets": "node --test scripts/check-maintenance-ssh-ca-secrets.test.mjs",
    "check:rust": "cargo check --workspace --all-targets",
    "check:script-inventory": "node --test scripts/check-repository-script-inventory.test.mjs && node scripts/check-repository-script-inventory.mjs",
    "check:vision-release-installer": "node --test scripts/windows/vision-release-install.test.mjs",
    "check:vm-host-adapter": "node --test scripts/testbed/default-audio-evidence.test.mjs scripts/testbed/display-evidence.test.mjs scripts/testbed/windows-native-audio-evidence.test.mjs scripts/testbed/vm-host-adapter-contract.test.mjs scripts/check-vm-runtime-acceptance-workflow.test.mjs scripts/check-active-runtime-factory-retirement.test.mjs",
    "fmt": "tsx node_modules/oxfmt/dist/cli.js . && cargo fmt --all",
    "fmt:check": "node tools/check-format.mjs",
    "generate:daemon-ipc-contracts": "NODE_OPTIONS=\"${NODE_OPTIONS:+$NODE_OPTIONS }--conditions=vem-source\" tsx scripts/daemon-ipc-contracts/generate-contracts.ts",
    "lint": "turbo lint",
    "lint:fix": "turbo lint -- --fix",
    "test": "node --test scripts/check-repository-script-inventory.test.mjs scripts/check-active-runtime-factory-retirement.test.mjs scripts/check-vm-runtime-acceptance-workflow.test.mjs scripts/testbed/machine-ui-cdp-driver.test.mjs && turbo test",
    "test:daemon-ipc-contracts": "NODE_OPTIONS=\"${NODE_OPTIONS:+$NODE_OPTIONS }--conditions=vem-source\" vitest run scripts/daemon-ipc-contracts/generate-contracts.spec.ts",
    "test:e2e": "turbo test:e2e",
    "typecheck": "turbo typecheck",
    "typecheck:scripts": "tsc -p tsconfig.scripts.json"
  },
  "dependencies": {
    "ajv": "8.20.0"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "catalog:",
    "@vem/shared": "workspace:*",
    "jsdom": "^29.1.1",
    "marked": "^18.0.5",
    "mermaid": "^11.15.0",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "oxlint-tsgolint": "^0.23.0",
    "playwright": "catalog:",
    "tsx": "catalog:",
    "turbo": "^2.10.0",
    "typescript": "catalog:",
    "unplugin-dts": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "yaml": "2.9.0"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
