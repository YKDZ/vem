{
  "name": "machine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vue-tsc --noEmit && vite build",
    "dev": "vite --host 0.0.0.0",
    "fmt": "oxfmt",
    "lint": "oxlint --quiet --format=unix --type-aware --config ../../oxlint.config.ts .",
    "lint-fix": "oxlint --format=unix --fix --type-aware --config ../../oxlint.config.ts .",
    "preview": "vite preview --host 0.0.0.0",
    "tauri": "tauri",
    "tauri:build:kiosk:windows": "tauri build --config src-tauri/tauri.windows.conf.json",
    "test": "NODE_OPTIONS=\"${NODE_OPTIONS:+$NODE_OPTIONS }--conditions=vem-source\" vitest run",
    "typecheck": "tsc --noEmit && vue-tsc --noEmit"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@vem/shared": "workspace:*",
    "axios": "catalog:",
    "mqtt": "^5.15.1",
    "pinia": "catalog:",
    "qrcode": "catalog:",
    "vue": "catalog:",
    "vue-router": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/vite": "catalog:",
    "@tauri-apps/cli": "2.11.4",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "catalog:",
    "@types/qrcode": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vision-mock": "workspace:*",
    "vite": "catalog:",
    "vitest": "catalog:",
    "vue-tsc": "catalog:"
  }
}
