{
  "name": "vision-mock",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "vem-source": {
        "types": "./src/server.ts",
        "default": "./src/server.ts"
      },
      "source": {
        "types": "./src/server.ts",
        "default": "./src/server.ts"
      },
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    }
  },
  "scripts": {
    "build": "tsc --noEmit",
    "dev": "NODE_OPTIONS=\"${NODE_OPTIONS:+$NODE_OPTIONS }--conditions=vem-source\" tsx src/server.ts",
    "fmt": "oxfmt",
    "lint": "oxlint --quiet --format=unix --type-aware --config ../../oxlint.config.ts .",
    "lint-fix": "oxlint --format=unix --fix --type-aware --config ../../oxlint.config.ts .",
    "test": "NODE_OPTIONS=\"${NODE_OPTIONS:+$NODE_OPTIONS }--conditions=vem-source\" vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vem/shared": "workspace:*",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/ws": "^8.18.1",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
