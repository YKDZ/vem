# service-api local development example. Copy values into repository root .env or process environment.
NODE_ENV=development
SERVICE_PORT=3000

# --- Database ---
DATABASE_URL=postgres://vem:vem_password@localhost:5432/vem

# --- Auth ---
JWT_SECRET=local-access-secret-change-before-production
JWT_REFRESH_SECRET=local-refresh-secret-change-before-production
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# --- MQTT ---
MQTT_URL=mqtt://localhost:1883
# 生产环境必须设置 MQTT_USERNAME 和 MQTT_PASSWORD
# MQTT_USERNAME=vem_service
# MQTT_PASSWORD=change-this-in-production
MQTT_SIGNATURE_TOLERANCE_SECONDS=300

# --- Payment: Mock (dev/test only) ---
# 生产环境强制禁用（NODE_ENV=production 时 PAYMENT_MOCK_ENABLED=true 会导致启动失败）
# 开发/测试环境保留为 true，生产部署前务必设置为 false
PAYMENT_MOCK_ENABLED=true
PAYMENT_WEBHOOK_BASE_URL=http://localhost:3000/api/payments/webhooks

# --- Payment: WeChat Pay (production) ---
# WECHAT_PAY_APP_ID=wx1234567890abcdef
# WECHAT_PAY_MCH_ID=1234567890
# WECHAT_PAY_API_V3_KEY=32-char-api-v3-key-change-in-production
# WECHAT_PAY_PRIVATE_KEY_PATH=/secrets/wechat-pay-private-key.pem
# WECHAT_PAY_CERT_SERIAL_NO=ABCDEF1234567890

# --- Payment: Alipay (production) ---
# ALIPAY_APP_ID=2021001234567890
# ALIPAY_PRIVATE_KEY_PATH=/secrets/alipay-private-key.pem
# ALIPAY_PUBLIC_KEY_PATH=/secrets/alipay-public-key.pem
# ALIPAY_NOTIFY_URL=https://api.example.com/api/payments/webhooks/alipay

# --- Notifications ---
# NOTIFICATION_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxx
# NOTIFICATION_SMTP_HOST=smtp.example.com
# NOTIFICATION_SMTP_PORT=465
# NOTIFICATION_SMTP_USER=noreply@example.com
# NOTIFICATION_SMTP_PASS=smtp-password-change-in-production
# NOTIFICATION_SMTP_FROM="VEM系统 <noreply@example.com>"

# --- Bootstrap Admin ---
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=local-admin-password-change-before-production

# --- Machine Auth ---
# MACHINE_JWT_SECRET: JWT 签名密钥，与管理员 JWT 分离，生产使用高熵随机值
# MACHINE_CREDENTIAL_ENCRYPTION_KEY: 生产必须来源于 KMS/Vault/密钥管理系统注入的 32 字节以上高熵值
#   短期使用环境变量时，CI/CD secret store 必须限制读取权限
#   轮换主密钥时新增 keyId 字段并批量重加密 mqtt_signing_secret_encrypted_json
#   不能在日志、审计或错误响应中输出解密后的 MQTT signing secret
MACHINE_JWT_SECRET=local-machine-jwt-secret-change-before-production-min32
MACHINE_CREDENTIAL_ENCRYPTION_KEY=local-cred-enc-key-change-before-production!
MACHINE_ACCESS_TTL_SECONDS=900