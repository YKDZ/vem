{
  "name": "service-api",
  "scripts": {
    "build": "nest build",
    "credentials:rotate-missing": "tsx src/machine-auth/rotate-existing-machine-credentials.cli.ts",
    "fmt": "oxfmt",
    "lint": "oxlint --type-aware",
    "lint-fix": "oxlint --fix --type-aware",
    "start": "pnpm run build && tsx dist/main.js",
    "start:debug": "nest start --debug --watch",
    "start:dev": "pnpm run build && tsx dist/main.js",
    "start:prod": "pnpm run start",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.17",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-express": "^11.1.11",
    "@nestjs/swagger": "^11.2.3",
    "@vem/db": "workspace:*",
    "@vem/shared": "workspace:*",
    "drizzle-orm": "catalog:",
    "helmet": "^8.1.0",
    "mqtt": "^5.14.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.8",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.3",
    "globals": "^15.14.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
