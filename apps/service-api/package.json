{
  "name": "service-api",
  "scripts": {
    "build": "nest build",
    "credentials:rotate-missing": "tsx src/machine-auth/rotate-existing-machine-credentials.cli.ts",
    "fmt": "oxfmt",
    "lint": "oxlint --type-aware",
    "lint-fix": "oxlint --fix --type-aware",
    "start": "pnpm run build && tsx dist/main.js",
    "start:debug": "nest start --debug --watch",
    "start:dev": "pnpm run build && tsx dist/main.js",
    "start:prod": "pnpm run start",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "testbed:prepare-vps-machine": "tsx src/testbed/prepare-vps-testbed-machine.cli.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/swagger": "^11.4.4",
    "@vem/db": "workspace:*",
    "@vem/shared": "workspace:*",
    "alipay-sdk": "4.14.0",
    "drizzle-orm": "catalog:",
    "fast-xml-parser": "^5.9.3",
    "helmet": "^8.2.0",
    "lunar-javascript": "^1.7.7",
    "mqtt": "^5.15.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.27",
    "@swc/cli": "^0.7.10",
    "@swc/core": "^1.15.43",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.1",
    "@types/supertest": "^7.2.0",
    "globals": "^17.7.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-loader": "^9.6.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
