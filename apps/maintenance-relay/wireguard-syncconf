#!/bin/sh
set -eu

if [ "$#" -ne 3 ]; then
  echo "usage: maintenance-relay-wireguard-syncconf INTERFACE PRIVATE_KEY_FILE PEER_CONFIG" >&2
  exit 64
fi

interface_name="$1"
private_key_path="$2"
peer_config_path="$3"

case "$interface_name" in
  '' | .* | *[!abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_.-]* | ????????????????*)
    echo "invalid WireGuard interface name" >&2
    exit 64
    ;;
esac

case "$peer_config_path" in
  /run/vem/maintenance-relay/vem-relay-wg-*/peers.conf) ;;
  *)
    echo "peer config must be inside the relay runtime tmpfs" >&2
    exit 64
    ;;
esac

test -r "$private_key_path"
test -f "$peer_config_path"
test "$(stat -c '%a' "$peer_config_path")" = "600"

config_directory="${peer_config_path%/*}"
umask 077
full_config_path="$(mktemp "$config_directory/syncconf.XXXXXX")"

cleanup() {
  rm -f -- "$full_config_path"
}
trap cleanup 0 1 2 15

{
  printf '[Interface]\nPrivateKey = '
  tr -d '\r\n' <"$private_key_path"
  printf '\nListenPort = 51820\n\n'
  cat "$peer_config_path"
} >"$full_config_path"
chmod 0600 "$full_config_path"

wg syncconf "$interface_name" "$full_config_path"

cleanup
trap - 0 1 2 15
