{
  "name": "@vem/shared",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "vem-source": {
        "types": "./src/index.ts",
        "default": "./src/index.ts"
      },
      "source": {
        "types": "./src/index.ts",
        "default": "./src/index.ts"
      },
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./schemas/*": {
      "vem-source": {
        "types": "./src/schemas/*.ts",
        "default": "./src/schemas/*.ts"
      },
      "source": {
        "types": "./src/schemas/*.ts",
        "default": "./src/schemas/*.ts"
      },
      "types": "./dist/schemas/*.d.ts",
      "import": "./dist/schemas/*.js",
      "require": "./dist/schemas/*.cjs",
      "default": "./dist/schemas/*.js"
    },
    "./fixtures/*": {
      "vem-source": {
        "types": "./src/fixtures/*.ts",
        "default": "./src/fixtures/*.ts"
      },
      "source": {
        "types": "./src/fixtures/*.ts",
        "default": "./src/fixtures/*.ts"
      },
      "types": "./dist/fixtures/*.d.ts",
      "import": "./dist/fixtures/*.js",
      "require": "./dist/fixtures/*.cjs",
      "default": "./dist/fixtures/*.js"
    },
    "./catalog-top-category": {
      "types": "./src/catalog-top-category.d.ts",
      "import": "./src/catalog-top-category.mjs",
      "default": "./src/catalog-top-category.mjs"
    }
  },
  "scripts": {
    "build": "vite build",
    "fmt": "oxfmt",
    "lint": "oxlint --quiet --format=unix --type-aware --config ../../oxlint.config.ts .",
    "lint-fix": "oxlint --format=unix --fix --type-aware --config ../../oxlint.config.ts .",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.lib.json --noEmit"
  },
  "dependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "unplugin-dts": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
