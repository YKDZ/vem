{
  "name": "@vem/db",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "vem-source": {
        "types": "./src/index.ts",
        "default": "./src/index.ts"
      },
      "source": {
        "types": "./src/index.ts",
        "default": "./src/index.ts"
      },
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "vite build",
    "fmt": "oxfmt",
    "generate": "drizzle-kit generate",
    "lint": "oxlint --quiet --format=unix --type-aware --config ../../oxlint.config.ts .",
    "lint-fix": "oxlint --format=unix --fix --type-aware --config ../../oxlint.config.ts .",
    "migrate": "drizzle-kit migrate",
    "studio": "drizzle-kit studio --host 0.0.0.0 --port 4983",
    "typecheck": "tsc -p tsconfig.lib.json --noEmit"
  },
  "dependencies": {
    "@vem/shared": "workspace:*",
    "dotenv": "catalog:",
    "drizzle-orm": "catalog:",
    "pg": "^8.22.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "unplugin-dts": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
